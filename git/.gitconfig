[user]
	email = vincentn337@gmail.com
	name = vincendiary
	signingkey = /home/vee/.ssh/id_ed25519.pub
[core]
	editor = cursor
	pager = delta

[interactive]
	diffFilter = delta --color-only

[delta]
	navigate = true  # use n and N to move between diff sections

[merge]
	conflictStyle = zdiff3
[gpg]
	format = ssh
[commit]
	gpgsign = true
